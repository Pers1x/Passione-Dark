{
  "$schema": "vscode://schemas/color-theme",
  "name": "Passione Dark",
  "type": "dark",
  "colors": {
    "focusBorder": "#f6c177",
    "foreground": "#d4d4d4",
    "disabledForeground": "#f6c1774c",
    "selection.background": "#80808022",
    "descriptionForeground": "#d4d4d4",
    "errorForeground": "#f48771",
    "textLink.foreground": "#7FBFE2",
    "textLink.activeForeground": "#f6c177",
    "textBlockQuote.background": "#262626",
    "textBlockQuote.border": "#80808059",
    "button.background": "#f6c177d1",
    "button.foreground": "#1f1f1f",
    "button.hoverBackground": "#f6c177",
    "dropdown.background": "#262626",
    "dropdown.border": "#80808059",
    "input.background": "#262626",
    "input.border": "#80808059",
    "input.foreground": "#d4d4d4",
    "input.placeholderForeground": "#8a8a8a",
    "activityBar.background": "#222222",
    "activityBar.foreground": "#d4d4d4",
    "activityBar.inactiveForeground": "#8a8a8a",
    "activityBarBadge.background": "#f6c177",
    "activityBarBadge.foreground": "#1f1f1f",
    "sideBar.background": "#222222",
    "sideBar.foreground": "#d4d4d4",
    "sideBar.border": "#80808059",
    "sideBarTitle.foreground": "#d4d4d4",
    "list.activeSelectionBackground": "#80808022",
    "list.activeSelectionForeground": "#d4d4d4",
    "list.hoverBackground": "#2b2b2b",
    "list.inactiveSelectionBackground": "#80808022",
    "list.highlightForeground": "#f6c177",
    "editor.background": "#1f1f1f",
    "editor.foreground": "#d4d4d4",
    "editorLineNumber.foreground": "#8a8a8a",
    "editorLineNumber.activeForeground": "#d4d4d4",
    "editorCursor.foreground": "#f6c177",
    "editor.selectionBackground": "#f6c17718",
    "editor.lineHighlightBackground": "#80808014",
    "editorIndentGuide.background1": "#8080802a",
    "editorIndentGuide.activeBackground1": "#8080803d",
    "editorWhitespace.foreground": "#8080802a",
    "editorGutter.background": "#1f1f1f",
    "editorWidget.background": "#262626",
    "editorWidget.border": "#80808059",
    "editorHoverWidget.background": "#262626",
    "editorHoverWidget.border": "#80808059",
    "editorSuggestWidget.background": "#262626",
    "editorSuggestWidget.border": "#80808059",
    "editorSuggestWidget.selectedBackground": "#80808022",
    "editorGroupHeader.tabsBackground": "#222222",
    "editorGroup.border": "#80808059",
    "tab.activeBackground": "#363636",
    "tab.activeForeground": "#d4d4d4",
    "tab.inactiveBackground": "#262626",
    "tab.inactiveForeground": "#8a8a8a",
    "tab.border": "#80808059",
    "panel.background": "#222222",
    "panel.border": "#80808059",
    "statusBar.background": "#262626",
    "statusBar.foreground": "#d4d4d4",
    "statusBar.noFolderBackground": "#262626",
    "titleBar.activeBackground": "#222222",
    "titleBar.activeForeground": "#d4d4d4",
    "titleBar.inactiveBackground": "#222222",
    "titleBar.inactiveForeground": "#8a8a8a",
    "terminal.background": "#1f1f1f",
    "terminal.foreground": "#d4d4d4",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiRed": "#cd3131",
    "terminal.ansiBrightRed": "#f14c4c",
    "terminal.ansiGreen": "#0dbc79",
    "terminal.ansiBrightGreen": "#23d18b",
    "terminal.ansiYellow": "#e5e510",
    "terminal.ansiBrightYellow": "#f5f543",
    "terminal.ansiBlue": "#2472c8",
    "terminal.ansiBrightBlue": "#3b8eea",
    "terminal.ansiMagenta": "#bc3fbc",
    "terminal.ansiBrightMagenta": "#d670d6",
    "terminal.ansiCyan": "#11a8cd",
    "terminal.ansiBrightCyan": "#29b8db",
    "terminal.ansiWhite": "#e5e5e5",
    "terminal.ansiBrightWhite": "#e5e5e5"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#7C7C7C", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "string.template", "constant.other.symbol"], "settings": { "foreground": "#B7D67A" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#B7D67A" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#aaa2ff", "fontStyle": "italic" } },
    { "scope": ["constant.numeric", "constant.language.boolean"], "settings": { "foreground": "#D8A657" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#7FBFE2" } },
    { "scope": ["entity.name.type", "support.type", "entity.name.class"], "settings": { "foreground": "#f6c177" } },
    { "scope": ["entity.name.tag", "variable", "variable.other", "support.variable"], "settings": { "foreground": "#eb6f92" } },
    { "scope": ["entity.other.attribute-name", "constant", "constant.other"], "settings": { "foreground": "#d19a66" } },
    { "scope": ["punctuation", "keyword.operator"], "settings": { "foreground": "#d4d4d4" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic", "foreground": "#FFFFFF" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold", "foreground": "#FFFFFF" } }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "stringLiteral": "#B7D67A",
    "regexp": "#B7D67A",
    "function": "#7FBFE2",
    "method": "#7FBFE2",
    "class": "#f6c177",
    "type": "#f6c177",
    "enum": "#A3BE8C",
    "parameter": "#d4d4d4",
    "variable": "#eb6f92",
    "property": "#d4d4d4"
  }
}
